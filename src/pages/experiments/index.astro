---
import Layout from '../../layouts/Layout.astro';

const experiments = [
  {
    title: '多智能体合作与竞争模拟',
    date: '2025 — 至今',
    status: '进行中',
    summary:
      '设计简单的智能体行为规则，观察在有限资源环境中合作与竞争模式的涌现。研究局部互动如何导致群体层面的策略分化与均衡形成。',
    platform: 'Agent Lab',
  },
  {
    title: '信息流动与网络结构演化',
    date: '2025 — 至今',
    status: '进行中',
    summary:
      '构建信息传播网络模型，研究信息不对称、传播延迟与网络拓扑如何共同影响群体决策与结构形成。关注小世界现象与无标度特性的涌现条件。',
    platform: 'Agent Lab',
  },
  {
    title: '价值形成的反馈动力学',
    date: '2025 — 至今',
    status: '规划中',
    summary:
      '模拟个体在供需互动中形成价值判断的过程。探讨承认、稀缺性与效用如何通过反馈循环驱动价值演化。',
    platform: 'Agent Lab',
  },
  {
    title: '可视化实验',
    date: '2025 — 至今',
    status: '持续进行',
    summary:
      '将 FRDVC 框架中的抽象关系——价值流动、欲望传播、承认网络、成本约束——转化为可感知的视觉形式。通过可视化揭示隐藏的结构与模式。',
    platform: '独立实验',
  },
];
---

<Layout>
  <main class="page">
    <h1>Experiments</h1>
    <p class="intro">
      通过设计简单规则，观察合作、竞争、资源流动、网络形成以及系统演化等现象。每一次实验，无论成功或失败，都将作为模型演化的重要依据。
    </p>

    <div class="method-bar">
      <span class="method-badge">实验方法</span>
      <span class="method-text">提出问题 → 建立模型 → 工程实现 → 实验观察 → 修正模型 → 持续迭代</span>
    </div>

    <div class="list">
      {
        experiments.map((exp) => (
          <article class="item">
            <div class="item-header">
              <time datetime={exp.date}>{exp.date}</time>
              <span class="platform">{exp.platform}</span>
              <span class={`status status--${exp.status === '进行中' ? 'active' : exp.status === '规划中' ? 'planned' : 'ongoing'}`}>
                {exp.status}
              </span>
            </div>
            <h2>{exp.title}</h2>
            <p>{exp.summary}</p>
          </article>
        ))
      }
    </div>

    <section class="section">
      <h2>实验哲学</h2>
      <blockquote class="quote">
        在受控的模拟环境中，复杂系统中最本质的动力学往往会在最简单的规则组合中浮现。我们的任务不是预设结果，而是创造让结果自己显现的条件。
      </blockquote>
    </section>
  </main>
</Layout>

<style>
  .page {
    max-width: 960px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  h1 {
    font-size: 36px;
    font-weight: 700;
    margin: 0 0 8px;
  }

  .intro {
    color: #4b5563;
    font-size: 17px;
    line-height: 1.7;
    margin: 0 0 28px;
  }

  .method-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 10px;
    margin-bottom: 40px;
  }

  .method-badge {
    display: inline-block;
    padding: 3px 12px;
    background: #166534;
    color: #fff;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    flex-shrink: 0;
  }

  .method-text {
    color: #166534;
    font-size: 14px;
    font-weight: 500;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .item {
    padding: 24px 28px;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    transition: box-shadow 0.2s;
  }

  .item:hover {
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
  }

  .item-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  time {
    color: #9ca3af;
    font-size: 13px;
  }

  .platform {
    display: inline-block;
    padding: 2px 10px;
    background: #eef2ff;
    color: #4338ca;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
  }

  .status {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
  }

  .status--active {
    background: #dcfce7;
    color: #166534;
  }

  .status--planned {
    background: #fef3c7;
    color: #92400e;
  }

  .status--ongoing {
    background: #e0e7ff;
    color: #3730a3;
  }

  .item h2 {
    font-size: 20px;
    margin: 6px 0 8px;
  }

  .item p {
    color: #4b5563;
    line-height: 1.65;
    margin: 0;
  }

  .section {
    margin-top: 56px;
  }

  .section h2 {
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid #e5e7eb;
  }

  .quote {
    border-left: 4px solid #6366f1;
    padding: 16px 24px;
    margin: 0;
    background: #fafafe;
    border-radius: 0 8px 8px 0;
    font-size: 16px;
    line-height: 1.7;
    color: #374151;
    font-style: italic;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 28px;
    }
  }
</style>